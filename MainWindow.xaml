<Window x:Class="ManagerComputer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lab Manager - Admin Panel" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e2e">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: PC List -->
        <StackPanel Grid.Column="0" Background="#2d2d3d">
            <TextBlock Text="🖥️ Connected PCs" Foreground="White"
                       FontSize="16" FontWeight="Bold" Margin="10,15,10,10"/>

            <ListBox x:Name="PcList" Background="Transparent"
                     BorderThickness="0"
                     SelectionChanged="PcList_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="5">
                            <Ellipse Width="10" Height="10" Margin="0,0,8,0"
                                     Fill="{Binding IsOnline, Converter={StaticResource BoolToBrushConverter}}"/>
                            <TextBlock Text="{Binding Name}" Foreground="White" FontSize="13"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>

        <!-- Right: Preview + Controls -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>

            <!-- Screen Preview -->
            <Border Grid.Row="0" Background="#12121e" Margin="10">
                <Image x:Name="ScreenPreview" Stretch="Uniform"/>
            </Border>

            <!-- Buttons -->
            <StackPanel Grid.Row="1" Orientation="Horizontal"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button Content="🔒 Lock" Width="110" Height="40" Margin="8"
                        FontSize="14" FontWeight="Bold"
                        Background="#e74c3c" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Click="LockButton_Click"/>
                <Button Content="🔓 Unlock" Width="110" Height="40" Margin="8"
                        FontSize="14" FontWeight="Bold"
                        Background="#2ecc71" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Click="UnlockButton_Click"/>
                <Button Content="🔒 Lock ALL" Width="130" Height="40" Margin="8"
                        FontSize="14" FontWeight="Bold"
                        Background="#c0392b" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Click="LockAllButton_Click"/>
                <Button Content="🔓 Unlock ALL" Width="130" Height="40" Margin="8"
                        FontSize="14" FontWeight="Bold"
                        Background="#27ae60" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Click="UnlockAllButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
<Window x:Class="ManagerComputer.Agent.LockOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Topmost="True"
        Background="Black"
        ShowInTaskbar="False">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="??" FontSize="80" 
                       HorizontalAlignment="Center" Foreground="White"/>
            <TextBlock Text="Computer Locked" FontSize="48" 
                       Foreground="White" HorizontalAlignment="Center"
                       Margin="0,20,0,0"/>
            <TextBlock Text="Please wait for your teacher." FontSize="20"
                       Foreground="Gray" HorizontalAlignment="Center"
                       Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</Window>
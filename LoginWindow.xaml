<Window x:Class="ManagerComputer.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lab Manager - Login" Height="400" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1e1e2e">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="300">

            <TextBlock Text="🖥️ Lab Manager" FontSize="28" FontWeight="Bold"
                       Foreground="White" HorizontalAlignment="Center"
                       Margin="0,0,0,30"/>

            <TextBlock Text="Username" Foreground="Gray" Margin="0,0,0,5"/>
            <TextBox x:Name="UsernameBox" Height="35" FontSize="14"
                     Background="#2d2d3d" Foreground="White"
                     BorderBrush="#555" Padding="8,5"/>

            <TextBlock Text="Password" Foreground="Gray" Margin="0,15,0,5"/>
            <PasswordBox x:Name="PasswordBox" Height="35" FontSize="14"
                         Background="#2d2d3d" Foreground="White"
                         BorderBrush="#555" Padding="8,5"/>

            <TextBlock x:Name="ErrorText" Foreground="#e74c3c" 
                       HorizontalAlignment="Center" Margin="0,10,0,0"
                       Visibility="Collapsed"/>

            <Button Content="Login" Height="40" Margin="0,20,0,0"
                    FontSize="16" FontWeight="Bold"
                    Background="#3498db" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="LoginButton_Click"/>
        </StackPanel>
    </Grid>
</Window>